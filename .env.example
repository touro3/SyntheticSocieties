# ── BGF API ────────────────────────────────────────────────────────────────────
# Bearer token for the REST API.  Set this before exposing api/app.py on a
# network.  Leave unset to run in open mode (local / trusted networks only).
# Generate a strong token with: python -c "import secrets; print(secrets.token_hex(32))"
BGF_API_TOKEN=

# ── Frontend auth token (must match BGF_API_TOKEN) ─────────────────────────────
# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# Set this to the same value as BGF_API_TOKEN so the frontend can authenticate.
# Leave empty when running in open mode (BGF_API_TOKEN is also empty).
VITE_BGF_API_TOKEN=

# ── LLM API keys ───────────────────────────────────────────────────────────────
# OpenAI API key — used by the GPT-4o-mini backend and the /report endpoint.
OPENAI_API_KEY=sk-...

# API key used exclusively by the /report endpoint.
# Falls back to OPENAI_API_KEY if not set.
BGF_REPORT_API_KEY=

# ── HuggingFace model cache ────────────────────────────────────────────────────
# Explicit cache directory for local HuggingFace model weights.
# BGF_MODEL_CACHE takes precedence over HF_HOME.  Both default to
# ~/.cache/huggingface when unset.
# BGF_MODEL_CACHE=/mnt/raid/workspace/lucastourinho/models
# HF_HOME=/mnt/raid/workspace/lucastourinho/models

# ── LLM API keys (simulation) ─────────────────────────────────────────────────
# Used when llm.backend_type = "groq" in the simulation config.
GROQ_API_KEY=gsk-...
